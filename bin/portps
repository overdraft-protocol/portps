#!/usr/bin/env bash
# portps — find (or kill) processes listening on TCP ports
set -e

MARKER="# portps shell integration"

# True if pattern uses wildcards (shell-safe %/_ or classic *?[]).
portps_is_glob() {
  case $1 in
    *'%'*|*'_'*|*'*'*|*'?'*|*'['*) return 0 ;;
    *) return 1 ;;
  esac
}

# Map SQL-like wildcards to shell globs: % → *, _ → ?
# Classic * ? [ patterns are left unchanged.
portps_to_shell_glob() {
  local p=$1
  p=${p//'%'/'*'}
  p=${p//'_'/'?'}
  printf '%s' "$p"
}

portps_usage() {
  cat <<'EOF' >&2
usage: portps [-k|--kill] <port|pattern>
       portps --setup-shell [zsh|bash|auto]
       portps --remove-shell

  shell-safe patterns (no quoting needed):
    portps 91%          ports starting with 91
    portps 9___         four-character ports starting with 9
    portps -k 91%

  classic globs (quote them, or run: portps --setup-shell):
    portps '91*'   portps '9???'   portps '90[01]*'
EOF
}

portps_install_zsh() {
  local zshrc="${ZSHRC:-$HOME/.zshrc}"
  if [[ ! -f $zshrc ]]; then
    touch "$zshrc"
  fi
  if grep -qF "$MARKER" "$zshrc" 2>/dev/null; then
    echo "portps: zsh integration already present in $zshrc"
    return 0
  fi
  cat >>"$zshrc" <<EOF

$MARKER
alias portps='noglob command portps'
EOF
  echo "portps: added noglob alias to $zshrc"
  echo "portps: run: source $zshrc"
  echo "portps: tip — or use shell-safe patterns: portps 91%"
}

portps_install_bash_note() {
  local bashrc="${BASHRC:-$HOME/.bashrc}"
  if [[ ! -f $bashrc ]]; then
    touch "$bashrc"
  fi
  if grep -qF "$MARKER" "$bashrc" 2>/dev/null; then
    echo "portps: bash note already present in $bashrc"
    return 0
  fi
  cat >>"$bashrc" <<EOF

$MARKER
# Prefer shell-safe patterns: portps 91%  (or quote: portps '91*')
EOF
  echo "portps: added bash pattern tip to $bashrc"
  echo "portps: run: source $bashrc"
  echo "portps: tip — prefer shell-safe patterns: portps 91%"
}

portps_setup_shell() {
  local which=${1:-auto}
  local shell_name
  shell_name=$(basename "${SHELL:-}")

  case $which in
    zsh) portps_install_zsh ;;
    bash)
      portps_install_bash_note
      echo "portps: prefer shell-safe patterns: portps 91%"
      ;;
    auto|"")
      case $shell_name in
        zsh) portps_install_zsh ;;
        bash)
          portps_install_bash_note
          echo "portps: prefer shell-safe patterns: portps 91%"
          ;;
        *)
          if [[ -f $HOME/.zshrc ]]; then
            portps_install_zsh
          elif [[ -f $HOME/.bashrc ]]; then
            portps_install_bash_note
          else
            echo "portps: tip — use shell-safe patterns: portps 91%"
            echo "portps: for classic * ? globs on zsh: portps --setup-shell zsh"
          fi
          ;;
      esac
      ;;
    *)
      echo "portps: unknown shell '$which' (use zsh, bash, or auto)" >&2
      return 1
      ;;
  esac
}

portps_remove_shell() {
  local rc
  for rc in "${ZSHRC:-$HOME/.zshrc}" "${BASHRC:-$HOME/.bashrc}"; do
    [[ -f $rc ]] || continue
    if grep -qF "$MARKER" "$rc" 2>/dev/null; then
      awk -v m="$MARKER" '
        $0 == m { skip=1; next }
        skip {
          if ($0 ~ /^#/ || $0 ~ /^alias /) next
          skip=0
        }
        { print }
      ' "$rc" >"$rc.tmp" && mv "$rc.tmp" "$rc"
      echo "portps: removed shell integration from $rc"
    fi
  done
}

portps_main() {
  local kill=0 pattern glob_pat port pid line name
  local -a matches unique killed
  local match seen u k glob=0
  local p pp user cmd

  case ${1:-} in
    -h|--help)
      portps_usage
      return 0
      ;;
    --setup-shell)
      shift
      portps_setup_shell "${1:-auto}"
      return $?
      ;;
    --remove-shell)
      portps_remove_shell
      return 0
      ;;
  esac

  if [[ ${1:-} == -k || ${1:-} == --kill ]]; then
    kill=1
    shift
  fi
  pattern=${1:-}
  if [[ -z $pattern ]]; then
    portps_usage
    return 1
  fi

  glob_pat=$(portps_to_shell_glob "$pattern")

  matches=()
  pid=""
  while IFS= read -r line || [[ -n $line ]]; do
    case $line in
      p*)
        pid=${line#p}
        if [[ ! $pid =~ ^[0-9]+$ ]]; then
          pid=""
        fi
        ;;
      n*)
        name=${line#n}
        port=${name##*:}
        port=${port%%\(*}
        if [[ -n $pid && $port =~ ^[0-9]+$ ]]; then
          if portps_is_glob "$pattern"; then
            # Right-hand side unquoted → shell glob match (portable bash).
            # shellcheck disable=SC2254
            [[ $port == $glob_pat ]] && matches+=("$port:$pid")
          else
            [[ $port == "$pattern" ]] && matches+=("$port:$pid")
          fi
        fi
        ;;
    esac
  done < <(lsof -nP -iTCP -sTCP:LISTEN -F pn 2>/dev/null || true)

  unique=()
  for match in "${matches[@]}"; do
    seen=0
    for u in "${unique[@]}"; do
      if [[ $u == "$match" ]]; then
        seen=1
        break
      fi
    done
    if (( !seen )); then
      unique+=("$match")
    fi
  done

  matches=()
  if ((${#unique[@]} > 0)); then
    while IFS= read -r match || [[ -n $match ]]; do
      [[ -n $match ]] && matches+=("$match")
    done < <(printf '%s\n' "${unique[@]}" | sort -t: -k1,1n)
  fi

  if ((${#matches[@]} == 0)); then
    echo "No process listening on port(s) matching: $pattern" >&2
    return 1
  fi

  if ((kill)); then
    killed=()
    for match in "${matches[@]}"; do
      port=${match%%:*}
      pid=${match##*:}
      for k in "${killed[@]}"; do
        [[ $k == "$pid" ]] && continue 2
      done
      if kill "$pid" 2>/dev/null; then
        echo "Killed PID $pid (port $port)"
        killed+=("$pid")
      else
        echo "Failed to kill PID $pid (port $port)" >&2
        return 1
      fi
    done
    return 0
  fi

  if portps_is_glob "$pattern"; then
    glob=1
  fi

  if ((${#matches[@]} == 1 && !glob)); then
    pid=${matches[0]##*:}
    if [[ ! $pid =~ ^[0-9]+$ ]]; then
      echo "No process listening on port(s) matching: $pattern" >&2
      return 1
    fi
    ps -p "$pid" -o pid,ppid,user,command
    return 0
  fi

  printf '%-8s %-7s %-7s %-8s %s\n' "PORT" "PID" "PPID" "USER" "COMMAND"
  for match in "${matches[@]}"; do
    port=${match%%:*}
    pid=${match##*:}
    while read -r p pp user cmd; do
      printf '%-8s %-7s %-7s %-8s %s\n' "$port" "$p" "$pp" "$user" "$cmd"
    done < <(ps -p "$pid" -o pid=,ppid=,user=,command= 2>/dev/null || true)
  done
}

portps_main "$@"
